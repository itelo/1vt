{
  "name": "@itelo/1vt",
  "version": "1.0.0",
  "description": "Vim-like terminal UI for 1Password",
  "type": "module",
  "bin": {
    "1vt": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "1password",
    "tui",
    "terminal",
    "vim",
    "ink",
    "cli"
  ],
  "author": "itelo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/itelo/1vt.git"
  },
  "homepage": "https://github.com/itelo/1vt",
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "clipboardy": "^5.3.1",
    "execa": "^9.6.1",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
